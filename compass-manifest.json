{
  "module": "frontend",
  "summary": "Smart Pet Care is a cross-platform React Native / Expo mobile app (iOS, Android, web) for managing pet health and care workflows. It provides email and Google OAuth authentication, a home dashboard with pet health cards, reminders, a care timeline, AI insights, and quick-action shortcuts. All HTTP traffic goes through a global axios instance configured with a JWT bearer-token interceptor and a 401 sign-out handler; the typed API client is auto-generated from an OpenAPI spec. UI is built with react-native-unistyles, shadcn-style primitive components (Button, Chip, Dialog, Drawer, Input, Select), and react-native-reanimated animations.",
  "techStack": [
    "TypeScript",
    "React Native",
    "Expo / Expo Router",
    "Axios",
    "TanStack React Query",
    "TanStack Form",
    "Zod",
    "react-native-unistyles",
    "react-native-reanimated",
    "@gorhom/bottom-sheet",
    "@rn-primitives",
    "@react-native-google-signin/google-signin",
    "expo-secure-store",
    "i18next / react-i18next",
    "dayjs"
  ],

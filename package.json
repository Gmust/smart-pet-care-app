{
  "name": "smart-pet-care-app",
  "main": "src/index.ts",
  "version": "1.0.0",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": "22.19.0"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios --device",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "check": "pnpm lint && pnpm typecheck",
    "api:fetch": "node --env-file-if-exists=.env ./scripts/fetch-openapi.mjs",
    "api:generate": "orval",
    "api:update": "pnpm api:fetch && pnpm api:generate",
    "postinstall": "pnpm api:generate",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo-google-fonts/fraunces": "0.4.1",
    "@expo/vector-icons": "15.0.3",
    "@gorhom/bottom-sheet": "5.2.9",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-google-signin/google-signin": "16.1.2",
    "@rn-primitives/dialog": "1.4.0",
    "@rn-primitives/dropdown-menu": "1.4.0",
    "@rn-primitives/portal": "1.4.0",
    "@rn-primitives/select": "1.4.0",
    "@rn-primitives/slot": "1.4.0",
    "@rn-primitives/switch": "1.4.0",
    "@tanstack/react-form": "1.32.0",
    "@tanstack/react-query": "5.97.0",
    "axios": "1.15.0",
    "dayjs": "1.11.20",
    "expo": "~56.0.4",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.16",
    "expo-constants": "~56.0.15",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-image-manipulator": "~56.0.19",
    "expo-image-picker": "~56.0.18",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.11",
    "expo-navigation-bar": "~56.0.3",
    "expo-router": "~56.2.6",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "i18next": "25.6.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "16.3.5",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-image-crop-picker": "^0.51.1",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-nitro-modules": "0.35.4",
    "react-native-reanimated": "~4.3.1",
    "react-native-reanimated-carousel": "4.0.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-toast-message": "2.3.3",
    "react-native-unistyles": "3.2.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.5",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.15",
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "8.60.1",
    "eslint": "9.39.4",
    "eslint-config-expo": "~56.0.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "jest-expo": "56.0.4",
    "lint-staged": "16.4.0",
    "orval": "8.14.0",
    "prettier": "3.8.1",
    "react-test-renderer": "19.1.0",
    "ts-node": "10.9.2",
    "typescript": "~6.0.3"
  },
  "private": true,
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}

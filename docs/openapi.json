  "components": {
    "schemas": {
      "AuthResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string"
          },
          "accessToken": {
            "type": "string"
          },
          "expiresAtUtc": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateReminderDto": {
        "type": "object",
        "properties": {
          "petId": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": ["null", "string"]
          },
          "type": {
            "$ref": "#/components/schemas/ReminderType"
          },
          "days": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DaysOfWeek"
            }
          },
          "isRepeatable": {
            "type": "boolean"
          },
          "time": {
            "type": "string",
            "format": "time"
          },
          "endAt": {
            "type": ["null", "string"],
            "format": "date-time"
          }
        }
      },
      "DaysOfWeek": {
        "enum": ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"]
      },
      "GoogleMobileRequest": {
        "type": "object",
        "properties": {
          "idToken": {
            "type": "string"
          }
        }
      },
      "LoginRequest": {
        "required": ["email", "password"],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "PatchReminderDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": ["null", "string"]
          },
          "description": {
            "type": ["null", "string"]
          },
          "days": {

# Copy to .env and fill in. .env is gitignored.

# Runtime API host the app talks to (Expo inlines EXPO_PUBLIC_* at build time).
# Root host only — the generated client appends paths like /api/reminders.
EXPO_PUBLIC_API_URL=

# --- Google OAuth (native idToken flow → POST /api/Auth/oauth/google/mobile) ---
# All three client IDs MUST live in the SAME Google Cloud project the backend
# validates idTokens against. WEB is the audience the backend checks.
# TODO(backender): waiting on the Web client ID / shared Google Cloud project.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# --- Maintainer-only: fetching a fresh OpenAPI spec (pnpm api:fetch) ---
# Basic-auth credentials for the backend spec endpoint.
OPENAPI_USERNAME=
OPENAPI_PASSWORD=
# Optional: override the spec URL (defaults to the duckdns host in the script).
OPENAPI_URL=

# Copy to .env and fill in. .env is gitignored.

# Runtime API host the app talks to (Expo inlines EXPO_PUBLIC_* at build time).
# Root host only — the generated client appends paths like /api/reminders.
EXPO_PUBLIC_API_URL=

# --- Maintainer-only: fetching a fresh OpenAPI spec (pnpm api:fetch) ---
# Basic-auth credentials for the backend spec endpoint.
OPENAPI_USERNAME=
OPENAPI_PASSWORD=
# Optional: override the spec URL (defaults to the duckdns host in the script).
OPENAPI_URL=
